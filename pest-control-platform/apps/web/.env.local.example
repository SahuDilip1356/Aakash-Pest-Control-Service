# Copy to .env.local and fill in values

# Which client config to load
SITE_CLIENT=aakash-pest-control

# Claude AI
ANTHROPIC_API_KEY=

# Google Calendar
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pestcontrol

# WhatsApp (optional — wa.link works without API key)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
